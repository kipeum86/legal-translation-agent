# Source documents (may contain confidential legal documents)
input/*
!input/.gitkeep

# User-managed Library assets (confidential)
library/*
!library/.gitkeep
!library/_example/
library/_example/inbox/*
!library/_example/inbox/.gitkeep
library/_example/references/*
!library/_example/references/en-ko/
library/_example/references/en-ko/source/*
!library/_example/references/en-ko/source/.gitkeep
library/_example/references/en-ko/target/*
!library/_example/references/en-ko/target/.gitkeep
library/_example/glossaries/*
!library/_example/glossaries/.gitkeep
library/_example/style-guides/*
!library/_example/style-guides/.gitkeep

# Output artifacts
output/documents/*
!output/documents/.gitkeep
output/working/*
!output/working/.gitkeep

# Glossary data (persistent, but user-specific)
glossary/*
!glossary/.gitkeep

# User-specific configuration (created via /setup onboarding)
config.json

# Private / internal work product (opaque; contents never tracked)
_private/*
!_private/.gitkeep

# Claude Code local-only settings (do not commit — may contain client filenames)
.claude/settings.local.json

# Python cache artifacts
__pycache__/
*.py[cod]

# OS files
.DS_Store
**/.DS_Store
