# User-managed Library example scaffolding stays in the repo.
# Real user data now lives outside the repo at $LEGAL_TRANSLATION_PRIVATE_DIR.
library/*
!library/.gitkeep
!library/_example/
library/_example/inbox/*
!library/_example/inbox/.gitkeep
library/_example/references/*
!library/_example/references/en-ko/
library/_example/references/en-ko/source/*
!library/_example/references/en-ko/source/.gitkeep
library/_example/references/en-ko/target/*
!library/_example/references/en-ko/target/.gitkeep
library/_example/glossaries/*
!library/_example/glossaries/.gitkeep
library/_example/style-guides/*
!library/_example/style-guides/.gitkeep

# Belt-and-suspenders guard: if someone recreates private data dirs in the repo,
# keep Git from tracking them.
input/
output/
glossary/
_private/

# User-specific configuration (created via /setup onboarding)
config.json

# Claude Code local-only settings (do not commit — may contain client filenames)
.claude/settings.local.json

# Env file (never commit real values)
.env
!.env.example

# Internal audit, review, and planning docs
docs/plans/
docs/notes/
docs/internal/
docs/audit/
*.review.md
*.audit.md
*.plan.md

# Build and test artifacts
build/
dist/
coverage/
htmlcov/
site/
.next/
.turbo/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
node_modules/

# Python cache artifacts
__pycache__/
*.py[cod]

# OS files
.DS_Store
**/.DS_Store
